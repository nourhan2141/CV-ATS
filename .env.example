# LLM Provider Configuration
# Options: "groq", "ollama", or "gemini"
LLM_PROVIDER=groq

# Default model to use
# For Groq: "llama-3.1-8b-instant", etc.
DEFAULT_MODEL=llama-3.1-8b-instant

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Environment and Data Persistence
# Set to true for local development
DEVELOPMENT_MODE=true
# Set to true to persist evaluation data (PII) to local disk
PERSIST_EVALUATION_DATA=true

# API Security
# Require this API key for the /evaluate endpoint
API_KEY=your_secure_api_key_here

# GitHub Token (optional but strongly recommended)
# Raises the GitHub API rate limit from 60/hr to 5000/hr. Essential for production.
GITHUB_TOKEN=your_github_token_here
